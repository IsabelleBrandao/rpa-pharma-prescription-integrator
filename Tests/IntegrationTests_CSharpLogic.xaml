      <ui:InvokeCode ContinueOnError="{x:Null}" Code="try&#xA;{&#xA;    // 1. Cenário Feliz: Receita válida de IGF com distribuidora autorizada de SP (ex: Braspress)&#xA;    string jsonFeliz = @&quot;{&#xA;        &quot;&quot;status&quot;&quot;: &quot;&quot;succeeded&quot;&quot;,&#xA;        &quot;&quot;analyzeResult&quot;&quot;: {&#xA;            &quot;&quot;content&quot;&quot;: &quot;&quot;Dr. Rodolfo de Souza\nMédico\nCRM 12345/SP\nPaciente: Maria da Silva\nCPF: 343.834.788-16\nReceita: (IGF+ HGH) - 2 unids\nValidade: 31/12/2026\nEmissão: 26/05/2026&quot;&quot;&#xA;        }&#xA;    }&quot;;&#xA;    var dtoFeliz = RPA_PHARMA.Infrastructure.Adapters.AzureAI.PrescriptionMapper.MapToDTO(jsonFeliz, &quot;Braspress&quot;);&#xA;    &#xA;    if (dtoFeliz.Medications == null || dtoFeliz.Medications.Count == 0)&#xA;    {&#xA;        string rawContent = Newtonsoft.Json.Linq.JObject.Parse(jsonFeliz).SelectToken(&quot;analyzeResult.content&quot;)?.ToString() ?? &quot;NULL&quot;;&#xA;        throw new Exception(&quot;Erro Diagnóstico: Nenhum medicamento identificado. ContentBlock lido: [&quot; + rawContent + &quot;]. Nome Paciente: &quot; + dtoFeliz.Patient.Name + &quot;, CRM: &quot; + dtoFeliz.Doctor.CRM);&#xA;    }&#xA;    &#xA;    var validator = new RPA_PHARMA.Core.Domain.PrescriptionComplianceValidator();&#xA;    validator.ValidateForProcessing(dtoFeliz); // Deve rodar sem lançar exceções.&#xA;    &#xA;    if (dtoFeliz.Patient.Name != &quot;MARIA DA SILVA&quot;)&#xA;        throw new Exception(&quot;Erro Teste 1: Nome do paciente não normalizado. Obtido: &quot; + dtoFeliz.Patient.Name);&#xA;    if (dtoFeliz.Doctor.CRM != &quot;12345&quot;)&#xA;        throw new Exception(&quot;Erro Teste 1: CRM não extraído. Obtido: &quot; + dtoFeliz.Doctor.CRM);&#xA;    if (dtoFeliz.Medications[0].Quantity != 2)&#xA;        throw new Exception(&quot;Erro Teste 1: Quantidade inválida. Obtido: &quot; + dtoFeliz.Medications[0].Quantity);&#xA;    if (string.IsNullOrEmpty(dtoFeliz.TransactionReference) || dtoFeliz.TransactionReference == &quot;00000000&quot;)&#xA;        throw new Exception(&quot;Erro Teste 1: Hash determinístico não foi gerado.&quot;);&#xA;&#xA;    // 2. Cenário de Bloqueio de Cadeia de Frio: Receita com Tirzepatida enviada por Sedex (deve falhar)&#xA;    string jsonColdChain = @&quot;{&#xA;        &quot;&quot;status&quot;&quot;: &quot;&quot;succeeded&quot;&quot;,&#xA;        &quot;&quot;analyzeResult&quot;&quot;: {&#xA;            &quot;&quot;content&quot;&quot;: &quot;&quot;Dr. Rodolfo de Souza\nMédico\nCRM 12345/SP\nPaciente: Maria da Silva\nCPF: 343.834.788-16\nReceita: (TIRZEPATIDA + B12) - 1 unids\nValidade: 31/12/2026\nEmissão: 26/05/2026&quot;&quot;&#xA;        }&#xA;    }&quot;;&#xA;    var dtoColdChain = RPA_PHARMA.Infrastructure.Adapters.AzureAI.PrescriptionMapper.MapToDTO(jsonColdChain, &quot;SEDEX&quot;);&#xA;    bool coldChainFailed = false;&#xA;    try&#xA;    {&#xA;        validator.ValidateForProcessing(dtoColdChain);&#xA;    }&#xA;    catch (RPA_PHARMA.Core.Domain.Exceptions.PharmaBusinessException ex) when (ex.Message.Contains(&quot;cadeia de frio&quot;))&#xA;    {&#xA;        coldChainFailed = true;&#xA;    }&#xA;    if (!coldChainFailed)&#xA;        throw new Exception(&quot;Erro Teste 2: Validador deveria barrar Tirzepatida sob transporte do Sedex.&quot;);&#xA;&#xA;    // 3. Cenário de Receita Vencida (deve falhar)&#xA;    string jsonVencida = @&quot;{&#xA;        &quot;&quot;status&quot;&quot;: &quot;&quot;succeeded&quot;&quot;,&#xA;        &quot;&quot;analyzeResult&quot;&quot;: {&#xA;            &quot;&quot;content&quot;&quot;: &quot;&quot;Dr. Rodolfo de Souza\nMédico\nCRM 12345/SP\nPaciente: Maria da Silva\nCPF: 343.834.788-16\nReceita: (IGF+ HGH) - 1 unids\nValidade: 01/01/2025\nEmissão: 26/05/2024&quot;&quot;&#xA;        }&#xA;    }&quot;;&#xA;    var dtoVencida = RPA_PHARMA.Infrastructure.Adapters.AzureAI.PrescriptionMapper.MapToDTO(jsonVencida, &quot;Braspress&quot;);&#xA;    bool vencidaFailed = false;&#xA;    try&#xA;    {&#xA;        validator.ValidateForProcessing(dtoVencida);&#xA;    }&#xA;    catch (RPA_PHARMA.Core.Domain.Exceptions.PharmaBusinessException ex) when (ex.Message.Contains(&quot;vencida&quot;))&#xA;    {&#xA;        vencidaFailed = true;&#xA;    }&#xA;    if (!vencidaFailed)&#xA;        throw new Exception(&quot;Erro Teste 3: Validador deveria barrar receita vencida.&quot;);&#xA;&#xA;    // 4. Cenário de CPF Inválido (deve falhar)&#xA;    string jsonCpfInvalido = @&quot;{&#xA;        &quot;&quot;status&quot;&quot;: &quot;&quot;succeeded&quot;&quot;,&#xA;        &quot;&quot;analyzeResult&quot;&quot;: {&#xA;            &quot;&quot;content&quot;&quot;: &quot;&quot;Dr. Rodolfo de Souza\nMédico\nCRM 12345/SP\nPaciente: Maria da Silva\nCPF: 123.456.789-00\nReceita: (IGF+ HGH) - 1 unids\nValidade: 31/12/2026\nEmissão: 26/05/2026&quot;&quot;&#xA;        }&#xA;    }&quot;;&#xA;    var dtoCpfInvalido = RPA_PHARMA.Infrastructure.Adapters.AzureAI.PrescriptionMapper.MapToDTO(jsonCpfInvalido, &quot;Braspress&quot;);&#xA;    bool cpfInvalidoFailed = false;&#xA;    try&#xA;    {&#xA;        validator.ValidateForProcessing(dtoCpfInvalido);&#xA;    }&#xA;    catch (RPA_PHARMA.Core.Domain.Exceptions.PharmaBusinessException ex) when (ex.Message.Contains(&quot;CPF: 12345678900) é inválido&quot;))&#xA;    {&#xA;        cpfInvalidoFailed = true;&#xA;    }&#xA;    if (!cpfInvalidoFailed)&#xA;        throw new Exception(&quot;Erro Teste 4: Validador deveria barrar CPF matemático inválido.&quot;);&#xA;&#xA;    // 5. Cenário de Estresse (ReDoS e Tamanho)&#xA;    var sb = new System.Text.StringBuilder();&#xA;    for (int i = 0; i &lt; 10000; i++)&#xA;    {&#xA;        sb.Append(&quot;Dr. Rodolfo de Souza Médico CRM 12345/SP Paciente: Nome Gigante CPF: 343.834.788-16 Receita: (IGF+ HGH) - 2 unids Validade: 31/12/2026 Emissão: 26/05/2026 &quot;);&#xA;    }&#xA;    string contentEstresse = sb.ToString();&#xA;    string jsonEstresse = @&quot;{&#xA;        &quot;&quot;status&quot;&quot;: &quot;&quot;succeeded&quot;&quot;,&#xA;        &quot;&quot;analyzeResult&quot;&quot;: {&#xA;            &quot;&quot;content&quot;&quot;: &quot;&quot;&quot; + contentEstresse + @&quot;&quot;&quot;&#xA;        }&#xA;    }&quot;;&#xA;    &#xA;    var sw = System.Diagnostics.Stopwatch.StartNew();&#xA;    var dtoEstresse = RPA_PHARMA.Infrastructure.Adapters.AzureAI.PrescriptionMapper.MapToDTO(jsonEstresse, &quot;Braspress&quot;);&#xA;    sw.Stop();&#xA;    &#xA;    if (sw.ElapsedMilliseconds &gt; 2000)&#xA;        throw new Exception(&quot;Erro Teste 5: Estouro de tempo (ReDoS). Tempo levado: &quot; + sw.ElapsedMilliseconds + &quot; ms.&quot;);&#xA;    &#xA;    out_TestSuccess = true;&#xA;    out_TestLog = &quot;Todos os 5 testes de integração e estresse foram concluídos com sucesso offline! Tempo do teste de estresse: &quot; + sw.ElapsedMilliseconds + &quot; ms.&quot;;&#xA;}&#xA;catch (Exception ex)&#xA;{&#xA;    out_TestSuccess = false;&#xA;    out_TestLog = &quot;FALHA NOS TESTES: &quot; + ex.Message + &quot;\nStack: &quot; + ex.StackTrace;&#xA;}&#xA;" DisplayName="Invoke Code" sap:VirtualizedContainerService.HintSize="388,197" sap2010:WorkflowViewState.IdRef="InvokeCode_1" Language="CSharp">
